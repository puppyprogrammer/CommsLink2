generator client {
  provider      = "prisma-client-js"
  output        = "./client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model user {
  id                 String    @id @default(uuid())
  username           String    @unique
  email              String?
  password_hash      String
  is_banned          Boolean   @default(false)
  is_admin           Boolean   @default(false)
  stripe_customer_id String?

  voice_id       String?
  volume         Float   @default(1.0)
  hear_own_voice Boolean @default(false)

  credit_balance      Int       @default(1000)
  last_free_credit_at DateTime?
  last_room_id   String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  messages             message[]
  llm_agents           llm_agent[]
  credit_transactions  credit_transaction[]
  credit_usage_logs    credit_usage_log[]
  machines             machine[]
  room_memberships         room_member[]
  payment_transactions     payment_transaction[]
  ffxiv_profile        ffxiv_profile?
  gladiators           gladiator[]
  player_characters    player_character[] @relation("PlayerCharacter")
  recruits             player_character[] @relation("CommanderRecruits")

  @@index([stripe_customer_id])
  @@index([username])
}

model room {
  id              String   @id @default(uuid())
  name            String   @unique
  display_name    String
  password_hash   String?
  is_permanent    Boolean  @default(false)
  memory_enabled      Boolean  @default(true)
  cmd_recall_enabled      Boolean  @default(true)
  cmd_sql_enabled         Boolean  @default(true)
  cmd_memory_enabled      Boolean  @default(true)
  cmd_selfmod_enabled     Boolean  @default(true)
  cmd_autopilot_enabled   Boolean  @default(true)
  cmd_mentions_enabled    Boolean  @default(true)
  cmd_terminal_enabled    Boolean  @default(false)
  cmd_claude_enabled      Boolean  @default(false)
  cmd_tokens_enabled      Boolean  @default(false)
  cmd_moderation_enabled  Boolean  @default(false)
  cmd_think_enabled       Boolean  @default(true)
  cmd_effort_enabled      Boolean  @default(false)
  cmd_audit_enabled       Boolean  @default(false)
  cmd_continue_enabled    Boolean  @default(false)
  cmd_agent_mgmt_enabled  Boolean  @default(false)
  cmd_intent_coherence_enabled  Boolean  @default(true)
  cmd_memory_coherence_enabled  Boolean  @default(true)
  max_loops               Int      @default(5)
  created_by          String?
  created_at      DateTime @default(now())

  messages            message[]
  llm_agents          llm_agent[]
  memory_summaries    memory_summary[]
  machine_permissions machine_permission[]
  members             room_member[]
  invites             room_invite[]

  @@index([name])
}

model message {
  id         String   @id @default(uuid())
  content    String   @db.Text
  type       String   @default("text")
  room_id    String
  author_id  String?
  username   String
  summarized Boolean  @default(false)
  created_at DateTime @default(now())

  author user? @relation(fields: [author_id], references: [id])
  room   room  @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@index([room_id, created_at])
  @@index([room_id, summarized])
  @@index([author_id, created_at])
}

model llm_agent {
  id                  String   @id @default(uuid())
  name                String
  room_id             String
  creator_id          String
  voice_id            String   @default("Joanna")
  model               String   @default("grok-4-1-fast-non-reasoning")
  system_instructions  String?  @db.Text
  memories             String?  @db.Text
  autopilot_enabled    Boolean  @default(false)
  autopilot_interval   Int      @default(300)
  autopilot_prompts    String?  @db.Text
  plan                 String?  @db.Text
  tasks                String?  @db.Text
  nicknames            String?  @db.Text
  max_tokens           Int      @default(2500)
  can_manage_agents    Boolean  @default(false)
  created_at           DateTime @default(now())

  creator user @relation(fields: [creator_id], references: [id])
  room    room @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@index([room_id])
  @@index([creator_id])
}

model credit_transaction {
  id            String   @id @default(uuid())
  user_id       String
  amount        Int
  balance_after Int
  type          String
  description   String?
  reference_id  String?
  created_at    DateTime @default(now())

  user user @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@index([type])
}

model credit_usage_log {
  id              String   @id @default(uuid())
  user_id         String
  service         String
  model           String?
  input_tokens    Int?
  output_tokens   Int?
  characters      Int?
  raw_cost_usd    Float
  credits_charged Int
  room_id         String?
  created_at      DateTime @default(now())

  user user @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@index([service])
}

model memory_summary {
  id               String   @id @default(uuid())
  room_id          String
  ref_name         String
  level            Int
  parent_id        String?
  content          String   @db.Text
  msg_start        DateTime
  msg_end          DateTime
  messages_covered Int
  embedding        Json?    // Stub for future vector search (array of floats)
  created_at       DateTime @default(now())

  room     room             @relation(fields: [room_id], references: [id], onDelete: Cascade)
  parent   memory_summary?  @relation("MemoryHierarchy", fields: [parent_id], references: [id])
  children memory_summary[] @relation("MemoryHierarchy")

  @@unique([room_id, ref_name])
  @@index([room_id, level])
  @@index([parent_id])
}

model machine {
  id         String   @id @default(uuid())
  name       String
  owner_id   String
  socket_id  String?
  status     String   @default("offline")
  os         String?
  last_seen  DateTime?
  created_at DateTime @default(now())

  owner       user                 @relation(fields: [owner_id], references: [id])
  permissions machine_permission[]

  @@unique([owner_id, name])
  @@index([owner_id])
  @@index([status])
}

model machine_permission {
  id         String  @id @default(uuid())
  machine_id String
  room_id    String
  enabled    Boolean @default(false)

  machine machine @relation(fields: [machine_id], references: [id], onDelete: Cascade)
  room    room    @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@unique([machine_id, room_id])
  @@index([machine_id])
  @@index([room_id])
}

model room_member {
  id      String @id @default(uuid())
  room_id String
  user_id String
  role    String @default("member")

  created_at DateTime @default(now())

  room room @relation(fields: [room_id], references: [id], onDelete: Cascade)
  user user @relation(fields: [user_id], references: [id])

  @@unique([room_id, user_id])
  @@index([room_id])
  @@index([user_id])
}

model app_version {
  id         String   @id @default(uuid())
  version    Int      @unique
  message    String?
  created_at DateTime @default(now())
}

model payment_transaction {
  id                        String   @id @default(uuid())
  user_id                   String
  stripe_session_id         String   @unique
  stripe_payment_intent_id  String?
  amount_usd                Int
  currency                  String   @default("usd")
  status                    String
  pack_id                   String?
  credits_granted           Int
  created_at                DateTime @default(now())

  user user @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@index([status])
}

model claude_log {
  id           String   @id @default(uuid())
  direction    String
  session_key  String
  machine_name String
  username     String
  room_name    String
  content      String   @db.Text
  created_at   DateTime @default(now())

  @@index([session_key])
  @@index([created_at])
}

model panel_log {
  id         String   @id @default(uuid())
  room_id    String
  tab        String   // 'terminal' or 'claude'
  entry_type String   // 'command', 'output', 'prompt', 'status', 'response', 'error'
  text       String   @db.Text
  machine    String?
  created_at DateTime @default(now())

  @@index([room_id, tab, created_at])
}

model room_invite {
  id         String    @id @default(uuid())
  room_id    String
  token      String    @unique
  created_by String
  expires_at DateTime?
  uses_left  Int?
  created_at DateTime  @default(now())

  room room @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@index([room_id])
  @@index([token])
}

model agent_template {
  id                  String   @id @default(uuid())
  name                String   @unique
  description         String?  @db.Text
  model               String   @default("grok-4-1-fast-non-reasoning")
  voice_id            String   @default("Joanna")
  system_instructions String?  @db.Text
  memories            String?  @db.Text
  autopilot_prompts   String?  @db.Text
  autopilot_interval  Int      @default(300)
  max_tokens          Int      @default(2500)
  created_at          DateTime @default(now())
}

model audit_log {
  id         String   @id @default(uuid())
  event      String
  username   String
  ip_address String?
  details    String?  @db.Text
  created_at DateTime @default(now())

  @@index([event])
  @@index([username])
  @@index([created_at])
}

model ffxiv_profile {
  id              String   @id @default(uuid())
  user_id         String   @unique
  content_id      String?
  char_name       String?
  voice_id        String   @default("Joanna")
  registration_ip String?  @db.VarChar(45)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user user @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([content_id])
}

// ┌──────────────────────────────────────────┐
// │ AI Fight Club                            │
// └──────────────────────────────────────────┘

model gladiator {
  id            String   @id @default(uuid())
  user_id       String
  name          String
  avatar_config Json?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  user  user             @relation(fields: [user_id], references: [id])
  stats gladiator_stats?

  memories         gladiator_memory[]
  fights_as_a      fight[]        @relation("FightGladiatorA")
  fights_as_b      fight[]        @relation("FightGladiatorB")
  fights_won       fight[]        @relation("FightWinner")
  fight_events     fight_event[]

  @@index([user_id])
  @@index([is_active])
}

model gladiator_stats {
  gladiator_id     String @id
  strength         Int    @default(50)
  speed            Int    @default(50)
  endurance        Int    @default(50)
  technique        Int    @default(50)
  level            Int    @default(1)
  experience_points Int   @default(0)
  elo_rating       Int    @default(1000)
  wins             Int    @default(0)
  losses           Int    @default(0)

  gladiator gladiator @relation(fields: [gladiator_id], references: [id], onDelete: Cascade)
}

model gladiator_memory {
  id            String   @id @default(uuid())
  gladiator_id  String
  memory_type   String   // strategy, opponent, general
  content       String   @db.Text
  priority      Int      @default(5)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  gladiator gladiator @relation(fields: [gladiator_id], references: [id], onDelete: Cascade)

  @@index([gladiator_id, memory_type])
  @@index([gladiator_id, is_active])
}

model fight {
  id               String   @id @default(uuid())
  gladiator_a_id   String
  gladiator_b_id   String
  winner_id        String?
  duration_seconds Int?
  replay_data      Json?
  elo_change_a     Int      @default(0)
  elo_change_b     Int      @default(0)
  is_ranked        Boolean  @default(false)
  status           String   @default("pending") // pending, simulating, completed, error
  created_at       DateTime @default(now())

  gladiator_a gladiator    @relation("FightGladiatorA", fields: [gladiator_a_id], references: [id])
  gladiator_b gladiator    @relation("FightGladiatorB", fields: [gladiator_b_id], references: [id])
  winner      gladiator?   @relation("FightWinner", fields: [winner_id], references: [id])
  events      fight_event[]

  @@index([gladiator_a_id])
  @@index([gladiator_b_id])
  @@index([winner_id])
  @@index([status])
  @@index([created_at])
}

model fight_event {
  id                   String  @id @default(uuid())
  fight_id             String
  timestamp_ms         Int
  actor_gladiator_id   String
  action               String  // strike, heavy_strike, block, dodge, clinch
  result               String  // hit, miss, blocked, dodged
  damage_dealt         Int     @default(0)
  stamina_cost         Int     @default(0)
  health_after_actor   Int
  health_after_target  Int
  stamina_after_actor  Int     @default(100)
  stamina_after_target Int     @default(100)
  ai_reasoning         String? @db.Text
  position_actor       Json?
  position_target      Json?

  fight    fight     @relation(fields: [fight_id], references: [id], onDelete: Cascade)
  actor    gladiator @relation(fields: [actor_gladiator_id], references: [id])

  @@index([fight_id, timestamp_ms])
  @@index([actor_gladiator_id])
}

// ┌──────────────────────────────────────────┐
// │ Game World — Player Characters           │
// └──────────────────────────────────────────┘

model player_character {
  id           String   @id @default(uuid())
  user_id      String
  name         String
  level        Int      @default(1)
  xp           Int      @default(0)
  max_health   Int      @default(100)
  max_stamina  Int      @default(100)
  strength     Int      @default(10)
  defense      Int      @default(10)
  speed        Int      @default(10)
  kills        Int      @default(0)
  deaths       Int      @default(0)
  spawn_x      Float    @default(2)
  spawn_y      Float    @default(0.5)
  spawn_z      Float    @default(-2)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Recruit system
  is_npc       Boolean  @default(false)
  commander_id String?
  npc_type     String?
  npc_class    String?
  is_alive     Boolean  @default(true)

  // Army structure
  rank         String   @default("soldier")  // soldier, sergeant, decurion, centurion
  maniple_id   Int?                           // 1-10, which maniple
  maniple_name String?                        // "Iron Guard", "Wolf Pack", etc.
  squad_id     String?                        // "a" or "b"

  // AI personality traits (0-100, set at creation, mostly static)
  trait_humor       Int @default(50)
  trait_obedience   Int @default(50)
  trait_bravery     Int @default(50)
  trait_curiosity   Int @default(50)
  trait_greed       Int @default(50)
  trait_aggression  Int @default(50)
  trait_verbosity   Int @default(50)

  // AI disposition (0-100, changes over time via Grok)
  mood              Int @default(50)   // 0=miserable, 100=joyful
  fear              Int @default(0)
  loyalty           Int @default(50)
  familiarity       Int @default(10)
  attraction        Int @default(0)
  warmth            Int @default(50)
  respect           Int @default(50)

  // AI needs (0-100, tick up over time)
  fatigue           Int @default(0)
  hunger            Int @default(0)
  procreation_drive Int @default(20)

  // AI behavior weights (0-100, adjusted by Grok)
  bw_aggression           Int @default(50)
  bw_defense              Int @default(50)
  bw_counter_attack       Int @default(50)
  bw_flank_tendency       Int @default(30)
  bw_flank_direction      Int @default(50)  // 0=always left, 100=always right, 50=no preference
  bw_retreat_threshold    Int @default(25)   // HP% to start retreating
  bw_pursuit              Int @default(50)
  bw_group_cohesion       Int @default(50)
  bw_commander_protection Int @default(50)
  bw_self_preservation    Int @default(50)

  // AI brain
  ai_instructions String? @db.Text  // Player-written natural language instructions
  ai_memories     String? @db.Text  // Accumulated memories (JSON array)
  ai_agenda       String  @default("follow_commander")
  ai_target_id    String? // Current target character ID

  user              user               @relation("PlayerCharacter", fields: [user_id], references: [id])
  commander         user?              @relation("CommanderRecruits", fields: [commander_id], references: [id])
  inventory_items   inventory_item[]
  shop_transactions shop_transaction[]

  @@index([user_id])
  @@index([commander_id])
  @@index([is_npc])
}

// ┌──────────────────────────────────────────┐
// │ Game World — Items & Inventory           │
// └──────────────────────────────────────────┘

model item_definition {
  id          String  @id @default(uuid())
  name        String  @unique
  description String? @db.Text
  icon_name   String
  item_type   String  // weapon, shield, helmet, chest, legs, boots, gloves, ring, amulet, consumable, material, quest
  slot        String? // main_hand, off_hand, head, chest, legs, feet, hands, ring, neck
  rarity      String  @default("common")
  stackable   Boolean @default(false)
  max_stack   Int     @default(1)

  strength_bonus  Int @default(0)
  defense_bonus   Int @default(0)
  speed_bonus     Int @default(0)
  health_bonus    Int @default(0)
  stamina_bonus   Int @default(0)

  buy_price   Int @default(0)
  sell_price   Int @default(0)

  created_at DateTime @default(now())

  inventory_items   inventory_item[]
  shop_stock        shop_stock[]
  shop_transactions shop_transaction[]

  @@index([item_type])
  @@index([rarity])
}

model inventory_item {
  id           String  @id @default(uuid())
  character_id String
  item_def_id  String
  quantity     Int     @default(1)
  slot_index   Int?
  is_equipped  Boolean @default(false)
  equip_slot   String?

  character player_character @relation(fields: [character_id], references: [id], onDelete: Cascade)
  item_def  item_definition  @relation(fields: [item_def_id], references: [id])

  created_at DateTime @default(now())

  @@index([character_id])
  @@index([character_id, is_equipped])
  @@unique([character_id, slot_index])
  @@unique([character_id, equip_slot])
}

// ┌──────────────────────────────────────────┐
// │ Game World — Leveling                    │
// └──────────────────────────────────────────┘

model level_definition {
  level       Int @id
  xp_required Int

  strength_bonus  Int @default(0)
  defense_bonus   Int @default(0)
  speed_bonus     Int @default(0)
  health_bonus    Int @default(0)
  stamina_bonus   Int @default(0)

  created_at DateTime @default(now())
}

// ┌──────────────────────────────────────────┐
// │ Game World — Shops                       │
// └──────────────────────────────────────────┘

model shop {
  id            String   @id @default(uuid())
  name          String   @unique
  display_name  String
  shop_type     String
  description   String?  @db.Text
  buy_markup    Float    @default(1.0)
  sell_discount Float    @default(0.5)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  stock        shop_stock[]
  transactions shop_transaction[]

  @@index([shop_type])
  @@index([is_active])
}

model shop_stock {
  id             String @id @default(uuid())
  shop_id        String
  item_def_id    String
  quantity       Int    @default(-1)
  price_override Int?

  shop     shop            @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  item_def item_definition @relation(fields: [item_def_id], references: [id])

  @@unique([shop_id, item_def_id])
  @@index([shop_id])
}

model shop_transaction {
  id           String   @id @default(uuid())
  shop_id      String
  character_id String
  item_def_id  String
  quantity     Int
  total_price  Int
  type         String
  created_at   DateTime @default(now())

  shop      shop             @relation(fields: [shop_id], references: [id])
  character player_character @relation(fields: [character_id], references: [id])
  item_def  item_definition  @relation(fields: [item_def_id], references: [id])

  @@index([shop_id, created_at])
  @@index([character_id, created_at])
}

// ┌──────────────────────────────────────────┐
// │ Game World — Battle Records              │
// └──────────────────────────────────────────┘

model battle_record {
  id                String   @id @default(uuid())
  army_a_user_id    String
  army_b_user_id    String
  winner_user_id    String?
  army_a_size       Int
  army_b_size       Int
  army_a_casualties Int      @default(0)
  army_b_casualties Int      @default(0)
  duration_seconds  Int?
  tier              String?
  tactics_a         String?  @db.Text
  tactics_b         String?  @db.Text
  status            String   @default("active") // active, completed, draw
  created_at        DateTime @default(now())

  @@index([army_a_user_id])
  @@index([army_b_user_id])
  @@index([winner_user_id])
  @@index([status])
}

// ┌──────────────────────────────────────────┐
// │ Game World — Vegetation / Ecosystem      │
// └──────────────────────────────────────────┘

model world_vegetation {
  id           Int      @id @default(autoincrement())
  x            Float
  z            Float
  type         String   @default("grass")
  growth_stage Int      @default(0)
  health       Int      @default(100)
  planted_at   DateTime @default(now())
  last_growth  DateTime @default(now())
  planted_by   String?

  @@index([x, z])
}

// ┌──────────────────────────────────────────┐
// │ Game World — NPC Placements              │
// └──────────────────────────────────────────┘

model world_npc {
  id              Int      @id @default(autoincrement())
  x               Float
  y               Float    @default(0)
  z               Float
  npc_name        String
  title           String
  shop_name       String
  prefab_name     String
  interact_range  Float    @default(3.5)
  placed_by       String?
  placed_at       DateTime @default(now())

  @@index([x, z])
}

// ┌──────────────────────────────────────────┐
// │ Game World — Objects (Buildings, Props)   │
// └──────────────────────────────────────────┘

model world_object {
  id           Int      @id @default(autoincrement())
  x            Float
  y            Float    @default(0)
  z            Float
  rot_y        Float    @default(0)
  scale        Float    @default(1)
  prefab_name  String
  category     String   @default("building")
  placed_by    String?
  placed_at    DateTime @default(now())
  is_static    Boolean  @default(true)
  health       Int?

  @@index([x, z])
}

model player_relation {
  id         Int      @id @default(autoincrement())
  user_id    String   // The player setting the relation
  target_id  String   // The player being classified
  relation   String   @default("neutral") // "enemy" | "neutral" | "ally"
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([user_id, target_id])
  @@index([user_id])
  @@index([target_id])
}

model vegetation_log {
  id         Int      @id @default(autoincrement())
  veg_id     Int
  veg_type   String
  event      String   // "spawned" | "grew" | "died" | "trampled"
  x          Float
  z          Float
  detail     String?  // e.g. "growth_stage: 2→3", "health: 20→0"
  created_at DateTime @default(now())

  @@index([veg_type])
  @@index([event])
  @@index([created_at])
}
