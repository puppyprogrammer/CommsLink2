{
  "name": "@commslink/terminal-agent",
  "version": "1.8.6",
  "description": "CommsLink Terminal Agent - allows AI to execute commands on connected machines",
  "main": "dist/index.js",
  "bin": {
    "commslink-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "package": "npm run build && npx pkg dist/index.js --targets node18-win-x64,node18-linux-x64 --output bin/commslink-agent --compress GZip && npm run copy-natives",
    "copy-natives": "node -e \"const fs=require('fs'),p=require('path');function cpR(s,d){fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>{const sf=p.join(s,f),df=p.join(d,f);fs.statSync(sf).isDirectory()?cpR(sf,df):fs.copyFileSync(sf,df)})}const src='node_modules/node-pty';['win32-x64','win32-arm64'].forEach(d=>{const dir=p.join(src,'prebuilds',d);if(fs.existsSync(dir))cpR(dir,p.join('bin','prebuilds',d))});const conpty=p.join(src,'build/Release/conpty');if(fs.existsSync(conpty))cpR(conpty,p.join('bin','build/Release/conpty'))\""
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "node_modules/node-pty/prebuilds/**/*",
      "node_modules/node-pty/build/Release/**/*"
    ],
    "outputPath": "bin"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "node-pty": "^1.1.0",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@yao-pkg/pkg": "^6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
